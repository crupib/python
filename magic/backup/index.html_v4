<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MTG Commander Deck Generator</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #282c34;
      color: white;
      text-align: center;
      margin: 20px;
    }
    .prompt-container {
      margin-bottom: 20px;
    }
    #userPrompt {
      width: 70%;
      padding: 12px;
      font-size: 18px;
      border-radius: 6px;
      border: 1px solid #ccc;
    }
    .button-group {
      margin-top: 10px;
    }
    button {
      padding: 12px 24px;
      font-size: 20px;
      color: white;
      background-color: #007bff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: background-color 0.3s;
      margin: 0 5px;
    }
    button:hover {
      background-color: #0056b3;
    }
    .loading {
      font-size: 18px;
      color: yellow;
      margin-top: 20px;
      display: none;
      text-align: center;
      position: relative;
      height: 70px;
    }
    .spinner-container {
      position: relative;
      display: inline-block;
    }
    .spinner {
      width: 50px;
      height: 50px;
      border: 6px solid #f3f3f3;
      border-top: 6px solid #3498db;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .timer {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 14px;
      font-weight: bold;
      color: white;
      animation: none;
    }
    .generation-complete {
      display: none;
      color: lightgreen;
      font-size: 20px;
      margin-top: 10px;
    }
    .deck-section {
      margin-top: 30px;
      text-align: left;
      width: 80%;
      margin: auto;
      padding: 10px;
      background-color: #333;
      border-radius: 8px;
    }
    .deck-section h2 {
      margin-bottom: 10px;
    }
    .total-count {
      font-size: 20px;
      margin-top: 10px;
      color: lightgreen;
    }
    .card-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
      margin-top: 20px;
    }
    .card {
      background-color: #444;
      border-radius: 8px;
      padding: 10px;
      text-align: center;
      width: 200px;
      box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2);
    }
    .card-name {
      color: lightblue;
      cursor: pointer;
      text-decoration: underline;
      font-size: 18px;
      user-select: none;
      margin-bottom: 8px;
    }
    .card img {
      width: 100%;
      border-radius: 5px;
      display: none;
    }
    .strategy-box {
      width: 80%;
      background-color: #222;
      padding: 10px;
      border-radius: 8px;
      margin: 20px auto;
      text-align: left;
      color: lightgray;
      font-size: 16px;
    }
    .strategy-box h2 {
      margin-bottom: 10px;
    }
    /* Prompt History Styles */
    #promptHistory {
      margin-top: 15px;
      text-align: left;
      width: 80%;
      margin-left: auto;
      margin-right: auto;
      background-color: #333;
      padding: 10px;
      border-radius: 8px;
    }
    #promptHistory h3 {
      margin-top: 0;
    }
    .history-item {
      cursor: pointer;
      color: lightblue;
      text-decoration: underline;
      margin: 5px 0;
    }
  </style>
</head>
<body>
  <h1>MTG Commander Deck Generator</h1>
  
  <div class="prompt-container">
    <input type="text" id="userPrompt" placeholder="Enter a deck theme">
    <div class="button-group">
      <button id="generateButton" onclick="generateDeck()">Generate Deck</button>
      <button id="clearButton" onclick="clearDeck()" style="display:none;">Clear</button>
    </div>
    <div id="promptHistory">
      <h3>Prompt History:</h3>
      <div id="historyList"></div>
    </div>
  </div>
  
  <div id="loadingMessage" class="loading">
    <div class="spinner-container">
      <div class="spinner"></div>
      <div class="timer" id="timerText">0s</div>
    </div>
    Generating deck... Please wait.
  </div>
  
  <div id="generationComplete" class="generation-complete">✅ Generation Complete!</div>
  
  <div id="totalCount" class="total-count"></div>
  
  <div id="deck-categories"></div>
  
  <!-- Notes and Strategy box (displayed at the bottom) -->
  <div id="strategyNotes" style="display: none;">
    <div class="strategy-box">
      <h2>Notes and Strategy</h2>
      <p id="strategyText"></p>
    </div>
  </div>

  <script>
    let timerInterval;
    let startTime;

    // Load prompt history from localStorage
    function loadPromptHistory() {
      let history = JSON.parse(localStorage.getItem("promptHistory")) || [];
      const historyList = document.getElementById("historyList");
      historyList.innerHTML = "";
      history.forEach(prompt => {
        const div = document.createElement("div");
        div.className = "history-item";
        div.textContent = prompt;
        div.onclick = () => {
          document.getElementById("userPrompt").value = prompt;
        };
        historyList.appendChild(div);
      });
    }

    // Add a new prompt to history
    function addPromptToHistory(prompt) {
      if (!prompt) return;
      let history = JSON.parse(localStorage.getItem("promptHistory")) || [];
      if (!history.includes(prompt)) {
        history.push(prompt);
        localStorage.setItem("promptHistory", JSON.stringify(history));
      }
      loadPromptHistory();
    }

    function updateTimer() {
      const now = Date.now();
      const elapsed = Math.floor((now - startTime) / 1000);
      document.getElementById("timerText").textContent = elapsed + "s";
    }

    function generateDeck() {
      document.getElementById("loadingMessage").style.display = "block";
      document.getElementById("generationComplete").style.display = "none";
      document.getElementById("strategyNotes").style.display = "none";
      document.getElementById("totalCount").textContent = "";
      document.getElementById("deck-categories").innerHTML = "";
      document.getElementById("clearButton").style.display = "none";
      
      const promptText = document.getElementById("userPrompt").value;
      addPromptToHistory(promptText);
      
      startTime = Date.now();
      timerInterval = setInterval(updateTimer, 1000);
      fetch("/generate_deck", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt: promptText })
      }).then(() => setTimeout(loadDeck, 5000));
    }

    function loadDeck() {
      fetch("/deck.json")
      .then(response => response.json())
      .then(data => {
        console.log("📄 Loaded Deck Data:", data);
        document.getElementById("loadingMessage").style.display = "none";
        document.getElementById("generationComplete").style.display = "block";
        clearInterval(timerInterval);
        document.getElementById("timerText").textContent = "";
  
        const categoriesContainer = document.getElementById("deck-categories");
        categoriesContainer.innerHTML = "";
  
        let overallTotal = 0;
        for (const [category, cards] of Object.entries(data.categories)) {
          if (category.toLowerCase().includes("land")) {
            overallTotal += cards.reduce((sum, card) => sum + card.quantity, 0);
          } else {
            overallTotal += cards.length;
          }
        }
        document.getElementById("totalCount").textContent = `Total Cards: ${overallTotal}`;
  
        Object.entries(data.categories).forEach(([category, cards]) => {
          let headerCount;
          if (category.toLowerCase().includes("land")) {
            headerCount = cards.reduce((sum, card) => sum + card.quantity, 0);
          } else {
            headerCount = cards.length;
          }
          let categoryTitle = `${category} (${headerCount})`;
          let sectionHTML = `<div class="deck-section"><h2>${categoryTitle}</h2><div class="card-container">`;
  
          cards.forEach((card, index) => {
            let quantityText = "";
            if (category.toLowerCase().includes("land") &&
                ["plains", "island", "swamp", "mountain", "forest"].includes(card.name.toLowerCase()) &&
                card.quantity > 1) {
              quantityText = ` (x${card.quantity})`;
            }
            let uniqueId = `${category.replace(/\s+/g, '_')}_${index}`;
            sectionHTML += `
              <div class="card">
                <p class="card-name" onclick="toggleImage('${uniqueId}', event)">${card.name}${quantityText}</p>
                <img id="card-image-${uniqueId}" src="${card.image}" alt="${card.name}">
              </div>`;
          });
          sectionHTML += `</div></div>`;
          categoriesContainer.innerHTML += sectionHTML;
        });
  
        if (data.notes) {
          document.getElementById("strategyText").textContent = data.notes;
          document.getElementById("strategyNotes").style.display = "block";
        }
        console.log("Raw ChatGPT Response:", data.raw_response);
        document.getElementById("clearButton").style.display = "inline-block";
      });
    }
  
    function clearDeck() {
      document.getElementById("deck-categories").innerHTML = "";
      document.getElementById("totalCount").textContent = "";
      document.getElementById("strategyNotes").style.display = "none";
      document.getElementById("generationComplete").style.display = "none";
      document.getElementById("clearButton").style.display = "none";
    }
  
    window.onload = function() {
      loadPromptHistory();
    };
  
    function toggleImage(id, event) {
      event.stopPropagation();
      let img = document.getElementById(`card-image-${id}`);
      img.style.display = (img.style.display === "none" || img.style.display === "") ? "block" : "none";
    }
  </script>
</body>
</html>

